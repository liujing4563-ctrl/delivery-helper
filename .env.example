# ===== AI 配置 =====
# 支持 OpenAI 兼容格式的 API（阿里云 Qwen、DeepSeek 等）
# 阿里云 Qwen（推荐）：
AI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-plus
# DeepSeek 备选：
# AI_API_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat
AI_API_KEY=your_api_key_here

# 不填写 AI_API_KEY 时，AI 助手会使用 mock 模式返回占位回答

# ===== SEO / 部署域名 =====
# 自定义域名或部署平台变更时只改环境变量，不改源码。
NEXT_PUBLIC_SITE_URL=https://delivery-helper.vercel.app
SITE_URL=https://delivery-helper.vercel.app

# ===== 认证配置 =====
# 当前 MVP 阶段暂不启用真实账号系统，不需要 AUTH_SECRET / RESEND_API_KEY。
